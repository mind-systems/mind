# =============================================================================
# PostgreSQL
# =============================================================================

POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
# MUST be the compose service name "postgres" — mind_api reaches the DB over
# the shared mind_net bridge network by service name, not localhost.
POSTGRES_HOST=
# MUST be 5432 — the stock postgres:15-alpine image always listens on 5432
# inside the container, and mind_api connects using port = CONTAINER_DB_PORT
# (database.config.ts:9). Any other value makes the API fail to reach the DB
# while pg_isready still passes on the default socket, masking the cause.
# HOST_DB_PORT is the only freely-chosen host-side mapping.
CONTAINER_DB_PORT=
HOST_DB_PORT=

# =============================================================================
# mind_api
# =============================================================================

NODE_ENV=
TZ=
HOST_API_PORT=
CONTAINER_API_PORT=
HOST_GRPC_PORT=
CONTAINER_GRPC_PORT=

JWT_SECRET=
JWT_EXPIRES_IN=

RESEND_API_KEY=

LOG_LEVEL=

APP_BASE_URL=
MAIL_FROM=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_IOS_CLIENT_ID=
WEB_REDIRECT_URI=
# Web dashboard origin — required for CORS. An empty value does NOT disable
# CORS: the API falls back to http://localhost:8000, silently blocking the
# deployed web dashboard. Set to the mind_web public origin (e.g. https://…).
FRONTEND_URL=

WS_RECONNECT_GRACE_MS=
WS_MIN_SESSION_DURATION_S=
WS_STREAM_MAX_BUFFER_BYTES=
WS_STREAM_MAX_SESSIONS=
WS_TELEMETRY_MAX_PAYLOAD_BYTES=
WS_BACKPRESSURE_SAMPLES_PER_SEC=

# MUST be 0.0.0.0:${CONTAINER_GRPC_PORT} — host 0.0.0.0 so the published port
# mapping is reachable from outside the container. An empty value does NOT fall
# back to the default: the API uses GRPC_URL ?? '0.0.0.0:50051', and nullish-
# coalescing does not catch empty string, so an empty GRPC_URL breaks the bind.
# The port inside GRPC_URL must equal CONTAINER_GRPC_PORT.
GRPC_URL=
GRPC_KEEPALIVE_TIME_MS=
GRPC_KEEPALIVE_TIMEOUT_MS=
GRPC_KEEPALIVE_PERMIT_WITHOUT_CALLS=

# =============================================================================
# mind_web
# =============================================================================

# prod: https://api.mind-awake.life  dev: https://dev-api.mind-awake.life
VITE_API_BASE_URL=
HOST_WEB_PORT=
# Scope note: root compose configures only VITE_API_BASE_URL for the web build.
# The web app also reads VITE_LOG_DESTINATION and VITE_OTLP_ENDPOINT at build
# time (mind_web/.env.example ships "file" / "/otlp/v1/logs"), but the current
# mind_web/Dockerfile only declares ARG VITE_API_BASE_URL, so those two fall
# back to compiled-in defaults. Per-deployment OTLP log shipping for the web
# app is out of scope here; enabling it requires adding ARG VITE_LOG_DESTINATION
# and ARG VITE_OTLP_ENDPOINT to mind_web/Dockerfile first.
